CREATE TABLE companies ( -- Table to store information about companies using the platform
    id SERIAL PRIMARY KEY, -- Unique identifier for each company using the platform
    name VARCHAR (255), -- The name of the company, e.g., "OpenAI", "Google", "Anthropic"
    industry VARCHAR (100), -- The industry the company operates in, e.g., 'Technology', 'Healthcare', 'Finance'
    region VARCHAR(100), -- The geographical region where the company is based, e.g., 'us-east-1'
    created_at TIMESTAMPTZ -- The date and time when the company was added to the database
);

CREATE TABLE ai_models ( -- Table to store information about AI models available on the platform
    id SERIAL PRIMARY KEY, -- Unique identifier for each AI model
    provider VARCHAR (100), -- The company providing the AI model, e.g., "OpenAI", "Google", "Anthropic"
    model_name VARCHAR (255), -- The name of the AI model, e.g., "GPT-4", "Bard", "Gemini"  
    model_type VARCHAR (50) -- The type of the AI model, e.g., "LLM", "Vision", "Multimodal"
);

CREATE TABLE ai_usage_sessions ( -- Table to store information about each AI usage session, including energy and carbon metrics 
    id BIGSERIAL PRIMARY KEY, -- Unique identifier for each AI usage session
    company_id INT REFERENCES companies(id), -- Foreign key referencing the company that used the AI model
    model_id INT REFERENCES ai_models(id), -- Foreign key referencing the AI model that was used
    session_type VARCHAR(20), -- The type of the AI usage session, e.g., 'inference', 'training'
    timestamp TIMESTAMPTZ, -- The date and time when the AI usage session occurred
    input_tokens INT, -- The number of tokens in the input to the AI model
    output_tokens INT, -- The number of tokens in the output from the AI model
    energy_consumed_wh DECIMAL(10,4), -- The amount of energy consumed during the AI usage session, in watt-hours
    carbon_emissions_kg DECIMAL(10,6), -- The amount of carbon emissions generated during the AI usage session, in kilograms
    water_consumed_ml DECIMAL(10,2), -- The amount of water consumed during the AI usage session, in milliliters
    response_time_ms DECIMAL(8,2), -- The response time of the AI model during the usage session, in milliseconds
    hardware_used VARCHAR(100), -- The hardware used during the AI usage session
    pue DECIMAL(4,3), -- The power usage effectiveness of the data center where the AI usage session occurred
    grid_carbon_intensity_gco2_per_kwh DECIMAL (8,2), -- The carbon intensity of the grid where the AI usage session occurred, in grams of CO2 per kWh
    region VARCHAR(100), -- The geographical region where the AI usage session occurred
    renewable_energy_percentage DECIMAL(5, 2) -- The percentage of renewable energy used in the data center where the AI usage session occurred
);

CREATE TABLE regional_factors ( -- Table to store regional factors that can be used to estimate energy and carbon metrics for AI usage sessions
    region VARCHAR(100) PRIMARY KEY, -- The geographical region, e.g., 'us-east-1', 'europe-west-1'
    avg_grid_carbon_intensity DECIMAL (8,2), -- The average carbon intensity of the grid in the region, in grams of CO2 per kWh
    water_stress_index DECIMAL (5,2), -- A measure of water stress in the region
    renewable_percentage DECIMAL (5,2), -- The percentage of renewable energy used in the region
    typical_pue DECIMAL(4,3) -- The typical power usage effectiveness of data centers in the region
);

CREATE TABLE users ( -- Table to store information about specific users per session
 company_id INT REFERENCES companies(id), -- Foreign key referencing the company the user belongs to
 id SERIAL PRIMARY KEY, -- Unique identifier for each user
 email VARCHAR(255) UNIQUE, -- The email address of the user, used for authentication and identification
 name VARCHAR(255), -- The full name of the user
 department VARCHAR(100), -- The department the user belongs to within the company, e.g., 'Engineering', 'Marketing', 'Sales'
 created_at TIMESTAMPTZ DEFAULT NOW() -- The date and time when the user was added to the database
);

ALTER TABLE ai_usage_sessions ADD COLUMN user_id INT REFERENCES users(id); -- Add a foreign key to link AI usage sessions to specific users, allowing for more granular tracking of AI usage and associated metrics at the user level.

ALTER TABLE ai_usage_sessions ADD COLUMN cost_usd DECIMAL(10,6); -- Add a column to store the estimated cost of each AI usage session in USD, allowing for cost tracking and analysis alongside energy and carbon metrics.  
ALTER TABLE ai_usage_sessions ADD COLUMN confidence_score DECIMAL(5,4); -- Add a column to store a confidence score to avoid greenwashing. This score can be calculated based on the quality of the data used for the AI session, the reliability of the model, and other factors that may affect the accuracy of the energy and carbon estimates. The confidence score can help users understand the level of uncertainty associated with the metrics provided for each AI usage session.

CREATE TABLE data_quality_log ( -- Table to log data quality checks performed on AI usage sessions, including any issues found and their severity
 id BIGSERIAL PRIMARY KEY, -- Unique identifier for each data quality check log entry
 session_id BIGINT REFERENCES ai_usage_sessions(id), -- Foreign key referencing the AI usage session that was checked for data quality
 check_name VARCHAR(100), -- The name of the data quality check performed, e.g.,'null_region', 'negative_tokens'
 severity VARCHAR(20), -- The severity of any issues found, e.g., 'Low', 'Medium', 'High'
 checked_at TIMESTAMPTZ DEFAULT NOW() -- The date and time when the data quality check was performed
);

CREATE TABLE usage_aggregates ( -- Table to store aggregated AI usage data for reporting and analysis, allowing for efficient querying of energy and carbon metrics at different time grains
 grain VARCHAR(10), -- 'day', 'week', 'month', 'year'
 period_start DATE, -- The start date of the aggregation period, e.g., '2024-01-01' for daily grain, '2024-01-01' for weekly grain (starting on Monday), '2024-01-01' for monthly grain, '2024-01-01' for yearly grain
 company_id INT REFERENCES companies(id), -- Foreign key referencing the company for which the aggregation is calculated
 total_sessions INT, -- The total number of AI usage sessions during the aggregation period for the company
 total_input_tokens INT, -- The total number of input tokens across all AI usage sessions during the
 total_carbon_kg DECIMAL(12,4), -- The total estimated carbon emissions from AI usage sessions during the aggregation period for the company
 total_energy_wh DECIMAL(12,2), -- The total energy consumption from AI usage sessions during the aggregation period for the company
 total_water_ml DECIMAL(12,2), -- The total water consumption from AI usage sessions during the aggregation period for the company
 avg_confidence DECIMAL(5,4),  -- The average confidence score for AI model outputs during the aggregation period for the company
 PRIMARY KEY (grain, period_start, company_id) -- Composite primary key to ensure uniqueness of each aggregation record for a given grain, period, and company
);

CREATE TABLE model_metrics ( -- Table to store specific metrics for each AI model, allowing for tracking of changes in cost, energy efficiency, and carbon intensity over time
 model_id INT REFERENCES ai_models(id),
 metric_name VARCHAR(100), -- 'cost_per_input_token', 'cost_per_output_token', 'energy_per_token_wh', 'baseline_carbon_per_token_kg', 'typical_response_time_ms'
 metric_value DECIMAL(12,6), -- The value of the metric for the AI model, which can be used for calculating estimated costs, energy consumption, and carbon emissions for AI usage sessions based on the number of input and output tokens
 unit VARCHAR(50), -- The unit of measurement for the metric value
 effective_date DATE, -- The date when the metric value became effective, allowing for tracking changes in model performance and efficiency over time
 PRIMARY KEY (model_id, metric_name, effective_date) -- Composite primary key to ensure uniqueness of each metric record for a given model, metric name, and effective date
);

ALTER TABLE companies ADD COLUMN plan_tier VARCHAR(50) DEFAULT 'free'; -- Add a column to indicate the subscription plan tier for each company, allowing for differentiation of features and limits based on the company's subscription level. Possible values could include 'free', 'pro', 'enterprise', etc.
ALTER TABLE companies ADD COLUMN billing_email VARCHAR(255); -- Add a column to store the billing email address for each company, allowing for communication regarding billing and subscription matters. This could be used to send invoices, payment reminders, and other billing-related communications to the appropriate contact within the company.    
ALTER TABLE companies ADD COLUMN is_active BOOLEAN DEFAULT TRUE; -- Add a column to indicate whether the company is currently active on the platform, allowing for filtering of active vs. inactive companies in queries and reports. This can help with managing subscriptions and identifying companies that may need follow-up regarding their account status.

ALTER TABLE ai_usage_sessions ADD COLUMN status VARCHAR(20) DEFAULT 'completed'; -- Add a column to track the status of each AI usage session, allowing for analysis of session outcomes and identification of common issues or failure points in AI usage. Possible values could include 'completed' for successful sessions, 'failed' for sessions that encountered errors, and 'pending' for sessions that are still in progress or awaiting processing.
ALTER TABLE ai_usage_sessions ADD COLUMN error_code VARCHAR(50); -- Add columns to track the status of each AI usage session (e.g., 'completed', 'failed', 'pending') and any error codes associated with failed sessions, allowing for analysis of session outcomes and identification of common issues or failure points in AI usage.

ALTER TABLE users ADD COLUMN role VARCHAR(20) DEFAULT 'viewer'; -- Add a column to indicate the role of each user within their company, allowing for role-based access control and differentiation of permissions on the platform. Possible values could include 'admin' for users with full access to all features and settings, 'viewer' for users with read-only access to reports and dashboards, and 'billing' for users with access to billing information and subscription management features.
ALTER TABLE users ADD COLUMN last_login TIMESTAMPTZ; -- Add a column to track the last login time for each user, allowing for analysis of user engagement and activity on the platform. This can help identify active vs. inactive users and inform strategies for user retention and support.

ALTER TABLE usage_aggregates ADD COLUMN total_output_tokens BIGINT; -- Add a column to store the total number of output tokens across all AI usage sessions during the aggregation period for the company, allowing for more detailed analysis of token usage trends and their relationship to energy and carbon metrics.
ALTER TABLE usage_aggregates ADD COLUMN total_cost_usd DECIMAL(12,2); -- Add a column to store the total estimated cost in USD for all AI usage sessions during the aggregation period for the company, allowing for cost analysis alongside energy and carbon metrics.

-- Constraints
ALTER TABLE ai_usage_sessions ADD CONSTRAINT chk_input_tokens CHECK (input_tokens >= 0); 
ALTER TABLE ai_usage_sessions ADD CONSTRAINT chk_output_tokens CHECK (output_tokens >= 0);
ALTER TABLE ai_usage_sessions ADD CONSTRAINT chk_energy CHECK (energy_consumed_wh >= 0);
ALTER TABLE ai_usage_sessions ADD CONSTRAINT chk_carbon CHECK (carbon_emissions_kg >= 0);
ALTER TABLE ai_usage_sessions ADD CONSTRAINT chk_water CHECK (water_consumed_ml >= 0);
ALTER TABLE ai_usage_sessions ADD CONSTRAINT chk_response_time CHECK (response_time_ms >= 0);
ALTER TABLE ai_usage_sessions ADD CONSTRAINT chk_pue CHECK (pue >= 1.0);
ALTER TABLE ai_usage_sessions ADD CONSTRAINT chk_grid_carbon CHECK (grid_carbon_intensity_gco2_per_kwh >= 0);
ALTER TABLE ai_usage_sessions ADD CONSTRAINT chk_renewable CHECK (renewable_energy_percentage BETWEEN 0 AND 100);
ALTER TABLE ai_usage_sessions ADD CONSTRAINT chk_cost CHECK (cost_usd >= 0);
ALTER TABLE ai_usage_sessions ADD CONSTRAINT chk_confidence CHECK (confidence_score BETWEEN 0 AND 1);

ALTER TABLE model_metrics ADD CONSTRAINT chk_metric_value CHECK (metric_value >= 0);

ALTER TABLE users ADD CONSTRAINT chk_role CHECK (role IN ('admin', 'viewer', 'billing'));

-- Indexes
CREATE INDEX idx_sessions_company_timestamp ON ai_usage_sessions (company_id, timestamp); -- Index to optimize queries filtering AI usage sessions by company and time range
CREATE INDEX idx_sessions_user ON ai_usage_sessions (user_id); -- Index to optimize queries filtering AI usage sessions by user
CREATE INDEX idx_sessions_model ON ai_usage_sessions (model_id); -- Index to optimize queries filtering AI usage sessions by AI model
CREATE INDEX idx_sessions_status ON ai_usage_sessions (status); -- Index to optimize queries filtering AI usage sessions by status (e.g., 'completed', 'failed', 'pending')
CREATE INDEX idx_aggregates_lookup ON usage_aggregates (company_id, grain, period_start); -- Index to optimize queries looking up usage aggregates for a specific company and time grain
CREATE INDEX idx_model_metrics_lookup ON model_metrics (model_id, effective_date DESC); -- Index to optimize queries looking up the most recent metrics for a specific AI model
CREATE INDEX idx_companies_active ON companies (is_active) WHERE is_active = TRUE; -- Partial index to optimize queries filtering for active companies
CREATE INDEX idx_dq_session ON data_quality_log (session_id); -- Index to optimize queries filtering data quality logs by AI usage session

